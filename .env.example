# Anthropic API — get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# GoHighLevel — paste your inbound webhook URL from GHL > Automation > Webhooks
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_LOCATION_ID/webhook-trigger/...

# Optional: GHL REST API (alternative to webhook — not required if GHL_WEBHOOK_URL is set)
# GHL_API_KEY=...
# GHL_LOCATION_ID=...
